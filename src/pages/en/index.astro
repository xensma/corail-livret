---
import Layout from '../../layouts/Layout.astro';
import { t, type Locale } from '../../i18n/ui';

// Import villa JSONs so capacity stays in sync with single source of truth
import kisara from '../../data/villas/kisara.json';
import laRhumiere from '../../data/villas/la-rhumiere.json';
import luminescence from '../../data/villas/luminescence.json';
import pimentBleu from '../../data/villas/piment-bleu.json';
import tikiReva from '../../data/villas/tiki-reva.json';
import mango from '../../data/villas/mango.json';
import verdea from '../../data/villas/verdea.json';
import reveIndigo from '../../data/villas/reve-indigo.json';
import prairies from '../../data/villas/prairies-turquoises.json';
import savannah from '../../data/villas/savannah.json';
import crystalBeach from '../../data/villas/crystal-beach.json';
import anBaSoleyLa from '../../data/villas/an-ba-soley-la.json';
import leDattier from '../../data/villas/le-dattier.json';
import belEscale from '../../data/villas/bel-escale.json';
import melyan from '../../data/villas/melyan.json';

const locale: Locale = 'en';

const villaConfigs = [
  { source: kisara,        extra: 'pool · Saint-François' },
  { source: laRhumiere,    extra: '100m to Lagoon' },
  { source: luminescence,  extra: 'infinity pool + jacuzzi · Louisiana Park' },
  { source: pimentBleu,    extra: 'pool · Louisiana Park' },
  { source: tikiReva,      extra: 'pool · Louisiana Park' },
  { source: mango,         extra: 'jacuzzi · 750m Raisins Clairs' },
  { source: verdea,        extra: 'sea view · Pointe des Châteaux', roomNoun: 'suites' },
  { source: reveIndigo,    extra: 'spa-jet pool · Saint-François' },
  { source: prairies,      extra: 'beachfront · Sainte-Anne' },
  { source: savannah,      extra: 'direct beach access' },
  { source: crystalBeach,  extra: '2 pools + badge-access beach' },
  { source: anBaSoleyLa,   extra: 'private pool · « under the sun »' },
  { source: leDattier,     extra: 'brand-new high-end · 5 min Raisins Clairs' },
  { source: belEscale,     extra: 'pool + pétanque court', roomNoun: 'suites' },
  { source: melyan,        extra: 'pool + carbet with plancha' }
];

const villas = villaConfigs.map((c) => ({
  id: c.source.id,
  name: c.source.name,
  tagline: `${c.source.capacity.bedrooms} ${c.roomNoun || 'BR'} · ${c.source.capacity.guests} guests · ${c.extra}`,
  status: 'live' as const
}));
---

<Layout title={`Corail Concierge — ${t(locale, 'indexTitle')}`} description={t(locale, 'indexSubtitle')}>
  <main class="min-h-screen bg-corail-cream py-16">
    <div class="container-narrow text-center mb-12">
      <img src="/brand/logo-corail.png" alt="Corail Conciergerie" class="h-20 md:h-24 mx-auto mb-8" />
      <div class="flex justify-center gap-1 bg-white rounded-full p-1 mb-8 w-fit mx-auto shadow-sm">
        <a href="/" class="text-sm font-medium px-4 py-1.5 rounded-full text-corail-ink/60 hover:text-corail-ink transition">FR</a>
        <a href="/en/" class="text-sm font-medium px-4 py-1.5 rounded-full bg-corail-turquoise text-white">EN</a>
      </div>
      <h1 class="font-display text-3xl md:text-4xl mb-3">{t(locale, 'indexTitle')}</h1>
      <p class="text-corail-ink/70">{t(locale, 'indexSubtitle')}</p>
    </div>

    <div class="container-wide grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {villas.map((v) => (
        v.status === 'live' ? (
          <a href={`/en/${v.id}`} class="card p-6 hover:scale-[1.02] transition-transform">
            <p class="text-xs uppercase tracking-wider text-corail-turquoise-dark mb-2">{t(locale, 'indexStatusLive')}</p>
            <h2 class="font-display text-2xl mb-1">{v.name}</h2>
            <p class="text-sm text-corail-ink/60">{v.tagline}</p>
            <p class="mt-4 text-sm text-corail-turquoise-dark">{t(locale, 'indexCTA')}</p>
          </a>
        ) : (
          <div class="card p-6 opacity-50">
            <p class="text-xs uppercase tracking-wider text-corail-ink/40 mb-2">{t(locale, 'indexStatusPending')}</p>
            <h2 class="font-display text-2xl mb-1">{v.name}</h2>
            <p class="text-sm text-corail-ink/50">{v.tagline}</p>
          </div>
        )
      ))}
    </div>
  </main>
</Layout>
