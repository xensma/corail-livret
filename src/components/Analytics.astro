---
// ───────────────────────────────────────────────────────────────────────────
// Analytics maison (first-party) — envoie les événements à /collect.php (O2switch).
// SANS cookie, SANS IP stockée (hash quotidien anonyme côté serveur) → aucun
// bandeau RGPD. Échecs silencieux : si le backend n'est pas (encore) configuré,
// le livret n'est ni cassé ni ralenti.
//   • page vue      : à chaque chargement
//   • clic sortant  : tout lien <a> vers un autre domaine (excursions, restos,
//                     cartes, sites officiels, WhatsApp wa.me…)
//   • événement     : tout élément portant  data-event="Nom"
//   • helper global : window.track('Nom')  pour des événements custom à venir
// ───────────────────────────────────────────────────────────────────────────
---

<script is:inline>
  (function () {
    var EP = '/collect.php';
    function send(p) {
      try {
        var body = JSON.stringify(p);
        if (navigator.sendBeacon) {
          navigator.sendBeacon(EP, new Blob([body], { type: 'application/json' }));
        } else {
          fetch(EP, { method: 'POST', body: body, headers: { 'Content-Type': 'application/json' }, keepalive: true }).catch(function () {});
        }
      } catch (e) {}
    }
    // villa + langue déduites du chemin : /mango → villa=mango ; /en/mango → en + mango
    var segs = location.pathname.split('/').filter(Boolean);
    var locale = 'fr', villa = null;
    if (segs[0] === 'en') { locale = 'en'; villa = segs[1] || null; }
    else { villa = segs[0] || null; }

    // Helper provider-agnostique pour des événements custom : track('Nom')
    window.track = function (name) {
      send({ t: 'event', n: String(name || ''), p: location.pathname, v: villa, l: locale });
    };

    // 1) page vue
    send({ t: 'pageview', p: location.pathname, v: villa, l: locale, r: (document.referrer || '').slice(0, 255) });

    // 2) clics sortants + 3) éléments data-event (capture pour attraper les clics sur enfants)
    document.addEventListener('click', function (e) {
      var el = e.target && e.target.closest ? e.target.closest('a[href],[data-event]') : null;
      if (!el) return;
      var ev = el.getAttribute('data-event');
      if (ev) send({ t: 'event', n: ev, p: location.pathname, v: villa, l: locale });
      var href = el.getAttribute('href');
      if (href && /^https?:\/\//i.test(href)) {
        var a = document.createElement('a'); a.href = href;
        if (a.host && a.host !== location.host) {
          send({ t: 'outbound', u: href.slice(0, 512), n: a.host, p: location.pathname, v: villa, l: locale });
        }
      }
    }, true);
  })();
</script>
