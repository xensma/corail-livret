---
import { t, tField, type Locale } from '../i18n/ui';

interface Props {
  resto: any;
  locale?: Locale;
}
const { resto, locale = 'fr' } = Astro.props;
const tagline = tField(resto, 'tagline', locale);
const specialty = tField(resto, 'specialty', locale);
const cuisine = tField(resto, 'cuisine', locale);
const notes = tField(resto, 'notes', locale);

const mapsUrl = `https://www.google.com/maps/dir/?api=1&destination=${resto.coordinates.lat},${resto.coordinates.lng}`;
const telUrl = resto.phone ? `tel:${resto.phone.replace(/\s/g, '')}` : null;
---

<article class="card flex flex-col group">
  <div class="aspect-[16/10] bg-corail-sand/30 overflow-hidden relative">
    <img
      src={resto.photo}
      alt={resto.name}
      loading="lazy"
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
      onerror="this.style.display='none'; this.parentElement.style.background='linear-gradient(135deg, #D9CDB4 0%, #E8E2D6 100%)';"
    />
    <div class="absolute top-3 left-3 flex gap-2">
      <span class="bg-white/95 backdrop-blur px-2.5 py-1 text-xs font-medium rounded-full">{resto.priceRange}</span>
      {resto.reservationRequired && (
        <span class="bg-corail-turquoise/90 text-white backdrop-blur px-2.5 py-1 text-xs font-medium rounded-full">{t(locale, 'btnReserver')}</span>
      )}
    </div>
    <div class="absolute top-3 right-3 bg-white/95 backdrop-blur px-2.5 py-1 text-xs font-medium rounded-full flex items-center gap-1">
      <span class="text-corail-accent">★</span>
      <span>{resto.rating}</span>
    </div>
  </div>

  <div class="p-5 flex-1 flex flex-col">
    <h3 class="text-xl mb-1">{resto.name}</h3>
    <p class="text-sm text-corail-ink/60 italic mb-3 font-display">{tagline}</p>

    <div class="flex flex-wrap gap-1 mb-3">
      {(cuisine || []).map((c: string) => <span class="chip">{c}</span>)}
    </div>

    <p class="text-sm text-corail-ink/70 mb-4">
      <span class="font-medium">{t(locale, 'lSpecialite')}</span> {specialty}
    </p>

    {notes && <p class="text-xs text-corail-ink/50 italic mb-3">{notes}</p>}

    <div class="mt-auto flex gap-2 pt-2 border-t border-corail-sand/30">
      {telUrl && (
        <a href={telUrl} class="btn-ghost" aria-label={`${t(locale, 'btnAppeler')} ${resto.name}`}>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"/></svg>
          {t(locale, 'btnAppeler')}
        </a>
      )}
      <a href={mapsUrl} target="_blank" rel="noopener" class="btn-ghost" aria-label={`${t(locale, 'btnItineraire')} ${resto.name}`}>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        {t(locale, 'btnItineraire')}
      </a>
    </div>
  </div>
</article>
