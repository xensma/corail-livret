---
import Layout from '../../layouts/Layout.astro';
import { t, type Locale } from '../../i18n/ui';

const locale: Locale = 'en';

const villas = [
  { id: 'kisara', name: 'Villa Kisara', tagline: '3 BR · 6 guests · pool · Saint-François', status: 'live' },
  { id: 'la-rhumiere', name: 'Villa la Rhumière', tagline: '4 BR · 8 guests · 100m to Lagoon', status: 'live' },
  { id: 'luminescence', name: 'Villa Luminescence', tagline: '3 BR · 6 guests · infinity pool + jacuzzi · Louisiana Park', status: 'live' },
  { id: 'piment-bleu', name: 'Villa Piment Bleu', tagline: '3 BR · 6 guests · pool · Louisiana Park', status: 'live' },
  { id: 'tiki-reva', name: 'Villa Tiki Reva', tagline: '3 BR · 6 guests · pool · Louisiana Park', status: 'live' },
  { id: 'mango', name: 'Villa Mango Eden Green', tagline: '3 BR · 6 guests · jacuzzi · 750m Raisins Clairs', status: 'live' },
  { id: 'verdea', name: 'Villa Verdéa', tagline: '3 suites · 6 guests · sea view · Pointe des Châteaux', status: 'live' },
  { id: 'reve-indigo', name: 'Villa Rêve Indigo', tagline: '3 BR · 6 guests · spa-jet pool · Saint-François', status: 'live' },
  { id: 'prairies-turquoises', name: 'Les Prairies Turquoises', tagline: '5 BR · 10 guests · beachfront · Sainte-Anne', status: 'live' },
  { id: 'savannah', name: 'Résidence Savannah', tagline: '2 BR · 4 guests · direct beach access', status: 'live' },
  { id: 'crystal-beach', name: 'N°72 Crystal Beach', tagline: '2 BR · 4 guests · 2 pools + badge-access beach', status: 'live' },
  { id: 'an-ba-soley-la', name: 'Villa An Ba Soley La', tagline: '3 BR · 6 guests · private pool · « under the sun »', status: 'live' },
  { id: 'le-dattier', name: 'Villa Le Dattier', tagline: '3 BR · 6 guests · brand-new high-end · 5 min Raisins Clairs', status: 'live' },
  { id: 'bel-escale', name: 'Villa Bel\'Escale', tagline: '3 suites · 6 guests · pool + pétanque court', status: 'live' },
  { id: 'melyan', name: 'Villa Melyan', tagline: '3 BR · 6 guests · pool + carbet with plancha', status: 'live' }
];
---

<Layout title={`Corail Concierge — ${t(locale, 'indexTitle')}`} description={t(locale, 'indexSubtitle')}>
  <main class="min-h-screen bg-corail-cream py-16">
    <div class="container-narrow text-center mb-12">
      <img src="/brand/logo-corail.png" alt="Corail Conciergerie" class="h-20 md:h-24 mx-auto mb-8" />
      <div class="flex justify-center gap-1 bg-white rounded-full p-1 mb-8 w-fit mx-auto shadow-sm">
        <a href="/" class="text-sm font-medium px-4 py-1.5 rounded-full text-corail-ink/60 hover:text-corail-ink transition">FR</a>
        <a href="/en/" class="text-sm font-medium px-4 py-1.5 rounded-full bg-corail-turquoise text-white">EN</a>
      </div>
      <h1 class="font-display text-3xl md:text-4xl mb-3">{t(locale, 'indexTitle')}</h1>
      <p class="text-corail-ink/70">{t(locale, 'indexSubtitle')}</p>
    </div>

    <div class="container-wide grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {villas.map((v) => (
        v.status === 'live' ? (
          <a href={`/en/${v.id}`} class="card p-6 hover:scale-[1.02] transition-transform">
            <p class="text-xs uppercase tracking-wider text-corail-turquoise-dark mb-2">{t(locale, 'indexStatusLive')}</p>
            <h2 class="font-display text-2xl mb-1">{v.name}</h2>
            <p class="text-sm text-corail-ink/60">{v.tagline}</p>
            <p class="mt-4 text-sm text-corail-turquoise-dark">{t(locale, 'indexCTA')}</p>
          </a>
        ) : (
          <div class="card p-6 opacity-50">
            <p class="text-xs uppercase tracking-wider text-corail-ink/40 mb-2">{t(locale, 'indexStatusPending')}</p>
            <h2 class="font-display text-2xl mb-1">{v.name}</h2>
            <p class="text-sm text-corail-ink/50">{v.tagline}</p>
          </div>
        )
      ))}
    </div>
  </main>
</Layout>
