---
import { t, type Locale } from '../i18n/ui';

interface Props {
  whatsapp: string;
  phone: string;
  villaName: string;
  locale?: Locale;
}
const { whatsapp, phone, villaName, locale = 'fr' } = Astro.props;
const waText = `${t(locale, 'waMessage')} ${villaName}.`;
const whatsappUrl = `https://wa.me/${whatsapp}?text=${encodeURIComponent(waText)}`;
---

<div class="fixed bottom-0 inset-x-0 z-40 bg-white/95 backdrop-blur-lg border-t border-corail-sand/30 shadow-2xl">
  <div class="container-wide flex items-center justify-between py-3 px-5">
    <div class="hidden md:block">
      <p class="text-xs text-corail-ink/60 uppercase tracking-wider">{t(locale, 'lVotreConciergerie')}</p>
      <p class="text-sm font-medium">{t(locale, 'lCorail7j7')}</p>
    </div>
    <div class="flex items-center gap-2 ml-auto">
      <a href={`tel:${phone}`} data-event="Appel concierge" class="btn-secondary text-sm" aria-label={t(locale, 'btnAppeler')}>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"/></svg>
        <span class="hidden sm:inline">{t(locale, 'btnAppeler')}</span>
      </a>
      <a href={whatsappUrl} target="_blank" rel="noopener" data-event="WhatsApp" class="btn-primary text-sm">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.5 14.4c-.3-.1-1.8-.9-2-1-.3-.1-.5-.1-.7.1-.2.3-.8 1-1 1.2-.2.2-.4.2-.7.1-.3-.1-1.3-.5-2.4-1.5-.9-.8-1.5-1.8-1.7-2.1-.2-.3 0-.5.1-.6.1-.1.3-.4.4-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.1-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.5s1.1 2.9 1.2 3.1c.1.2 2.1 3.3 5.2 4.6.7.3 1.3.5 1.7.6.7.2 1.4.2 1.9.1.6-.1 1.8-.7 2-1.5.3-.7.3-1.4.2-1.5-.1-.1-.3-.2-.5-.3zM12 2C6.5 2 2 6.5 2 12c0 1.9.5 3.7 1.5 5.3L2 22l4.8-1.5c1.5.9 3.3 1.4 5.2 1.4 5.5 0 10-4.5 10-10S17.5 2 12 2z"/></svg>
        {t(locale, 'btnWhatsApp')}
      </a>
    </div>
  </div>
</div>
