---
import servicesData from '../data/saint-francois/services-corail.json';
import { t, tField, type Locale } from '../i18n/ui';

interface Props {
  whatsapp: string;
  locale?: Locale;
}
const { whatsapp, locale = 'fr' } = Astro.props;

const intro = locale === 'en' ? (servicesData as any).intro_en : servicesData.intro;

const ICONS: Record<string, string> = {
  boat: 'M2 21l1.65-3.6a8 8 0 0 1 14.7 0L20 21M8 9l4-4 4 4M12 5v10',
  car: 'M3 17h2l1-3h12l1 3h2v-4l-2-5H5l-2 5v4zM7 17a2 2 0 1 0 0 4 2 2 0 0 0 0-4zM17 17a2 2 0 1 0 0 4 2 2 0 0 0 0-4z',
  compass: 'M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10zM16.24 7.76l-2.83 7.07-7.07 2.83 2.83-7.07 7.07-2.83z',
  shopping: 'M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4H6zM3 6h18M16 10a4 4 0 0 1-8 0',
  chef: 'M6 13.87A4 4 0 0 1 7.41 6a5.11 5.11 0 0 1 1.05-1.54 5 5 0 0 1 7.08 0A5.11 5.11 0 0 1 16.59 6 4 4 0 0 1 18 13.87V21H6Z M6 17h12',
  baby: 'M9 12h.01M15 12h.01M10 16c.5.3 1.2.5 2 .5s1.5-.2 2-.5M19 6.3a9 9 0 0 1 1.8 3.9 2 2 0 0 1 0 3.6 9 9 0 0 1-17.6 0 2 2 0 0 1 0-3.6A9 9 0 0 1 12 3c2 0 3.5 1.1 3.5 2.5s-.9 2.5-2 2.5c-.8 0-1.5-.4-1.5-1',
  yoga: 'M12 2a2 2 0 1 0 0 4 2 2 0 0 0 0-4zM12 6v6M6 22l3-9 3 0M18 22l-3-9-3 0M10 13l4 0',
  spa: 'M12 2L9 6h6l-3-4zM12 6v4M5 14a7 7 0 0 0 14 0c0-2-1-3-2-3-1 0-1.5 1-2 1s-1-1-3-1-2.5 1-3 1-1-1-2-1c-1 0-2 1-2 3z'
};
---

<div class="space-y-6">
  <p class="font-display italic text-lg text-corail-ink/80 max-w-2xl">{intro}</p>

  <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
    {servicesData.services.map((s: any) => {
      const name = tField(s, 'name', locale);
      const description = tField(s, 'description', locale);
      return (
        <div class="card p-5 group hover:border-corail-turquoise transition-colors">
          <div class="w-10 h-10 rounded-full bg-corail-turquoise/15 flex items-center justify-center mb-3 group-hover:bg-corail-turquoise/30 transition-colors">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#5BA8A2" stroke-width="1.8">
              <path d={ICONS[s.icon] || ICONS.compass} />
            </svg>
          </div>
          <h3 class="text-lg font-display mb-1">{name}</h3>
          <p class="text-sm text-corail-ink/70 mb-4">{description}</p>
          <a href={`https://wa.me/${whatsapp}?text=${encodeURIComponent((locale === 'en' ? 'Hello Corail, I would like to book: ' : 'Bonjour Corail, je souhaite réserver : ') + name)}`} target="_blank" rel="noopener" class="btn-ghost text-xs">
            {t(locale, 'btnReserverWA')}
          </a>
        </div>
      );
    })}
  </div>
</div>
