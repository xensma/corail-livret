---
import QRCode from 'qrcode';
import { t, type Locale } from '../i18n/ui';

interface WifiNetwork {
  ssid: string;
  password: string;
  security?: string;
  notes?: string;
  label?: string;     // facultatif : nom du réseau (ex: "Orange Fibre", "Réseau secondaire")
}

interface Props {
  wifi: WifiNetwork | WifiNetwork[];
  locale?: Locale;
}

const { wifi, locale = 'fr' } = Astro.props;

// Accepte soit un seul réseau (objet) soit une liste de réseaux (array).
const networks: WifiNetwork[] = Array.isArray(wifi) ? wifi : [wifi];

// Génère un QR code par réseau au build time.
async function makeQr(n: WifiNetwork) {
  const wifiString = `WIFI:T:${n.security || 'WPA'};S:${n.ssid};P:${n.password};;`;
  const rawSvg = await QRCode.toString(wifiString, {
    type: 'svg', errorCorrectionLevel: 'M', margin: 1, width: 200,
    color: { dark: '#1F2A2E', light: '#F5F2ED' }
  });
  return rawSvg
    .replace(/\swidth="[^"]+"/, '')
    .replace(/\sheight="[^"]+"/, '')
    .replace('<svg ', '<svg width="100%" height="100%" preserveAspectRatio="xMidYMid meet" ');
}

const networksWithQr = await Promise.all(
  networks.map(async (n, i) => ({
    ...n,
    qrSvg: await makeQr(n),
    defaultLabel: networks.length > 1
      ? (locale === 'en' ? `Network ${i + 1}` : `Réseau ${i + 1}`)
      : null
  }))
);

const multi = networksWithQr.length > 1;
---

<div class="space-y-5">
  {networksWithQr.map((n) => (
    <div class="bg-corail-cream rounded-2xl p-5 md:p-6">
      <div class="flex items-start gap-4 mb-3">
        <div class="w-10 h-10 rounded-full bg-corail-turquoise/20 flex items-center justify-center flex-shrink-0">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#5BA8A2" stroke-width="2"><path d="M5 12.55a11 11 0 0 1 14.08 0M1.42 9a16 16 0 0 1 21.16 0M8.53 16.11a6 6 0 0 1 6.95 0M12 20h.01"/></svg>
        </div>
        <div class="flex-1">
          <p class="text-xs uppercase tracking-wider text-corail-turquoise-dark mb-2">{t(locale, 'tWifi')}</p>
          <h3 class="text-xl font-display">
            {multi ? (n.label || n.defaultLabel) : t(locale, 'hConnexionInternet')}
          </h3>
        </div>
      </div>

      <div class="grid md:grid-cols-[1fr,auto] gap-5 items-center">
        <div class="space-y-3">
          <div>
            <p class="text-xs text-corail-ink/50 uppercase tracking-wider mb-1">{t(locale, 'lReseau')}</p>
            <div class="flex items-center gap-2">
              <code class="font-mono text-sm bg-white px-3 py-1.5 rounded-lg border border-corail-sand/30">{n.ssid}</code>
              <button data-copy={n.ssid} data-copied-label={t(locale, 'btnCopie')} class="btn-ghost text-xs">{t(locale, 'btnCopier')}</button>
            </div>
          </div>
          <div>
            <p class="text-xs text-corail-ink/50 uppercase tracking-wider mb-1">{t(locale, 'lMotDePasse')}</p>
            <div class="flex items-center gap-2">
              <code class="font-mono text-sm bg-white px-3 py-1.5 rounded-lg border border-corail-sand/30">{n.password}</code>
              <button data-copy={n.password} data-copied-label={t(locale, 'btnCopie')} class="btn-ghost text-xs">{t(locale, 'btnCopier')}</button>
            </div>
          </div>
          {n.notes && <p class="text-xs text-corail-ink/60 italic mt-3">{n.notes}</p>}
        </div>

        <div class="flex flex-col items-center justify-center bg-white rounded-xl p-4 border border-corail-sand/30 w-fit mx-auto md:mx-0">
          <div class="qr-svg w-36 h-36 md:w-40 md:h-40" set:html={n.qrSvg} />
          <p class="text-[10px] uppercase tracking-wider text-corail-ink/60 mt-3 text-center whitespace-pre-line">{t(locale, 'lScannerWifi')}</p>
        </div>
      </div>
    </div>
  ))}
</div>
