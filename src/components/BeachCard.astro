---
import { t, tField, type Locale } from '../i18n/ui';

interface Props {
  beach: any;
  locale?: Locale;
}
const { beach, locale = 'fr' } = Astro.props;
const name = tField(beach, 'name', locale);
const tagline = tField(beach, 'tagline', locale);
const description = tField(beach, 'description', locale);
const facilities = tField(beach, 'facilities', locale) || [];
const bestTime = tField(beach, 'bestTime', locale);

const mapsUrl = `https://www.google.com/maps/dir/?api=1&destination=${beach.coordinates.lat},${beach.coordinates.lng}`;
---

<article class={`card group ${beach.highlight ? 'ring-2 ring-corail-accent/40' : ''}`}>
  <div class="aspect-[16/9] bg-corail-turquoise-light overflow-hidden relative">
    <img src={beach.photo} alt={name} loading="lazy" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" onerror="this.style.display='none';" />
    {beach.highlight && (
      <div class="absolute top-3 left-3 inline-flex items-center gap-1.5 bg-corail-accent text-white text-xs uppercase tracking-wider px-3 py-1.5 rounded-full font-semibold shadow-lg">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
        {t(locale, 'lCoupDeCoeur')}
      </div>
    )}
  </div>
  <div class="p-5">
    <h3 class="text-xl mb-1">{name}</h3>
    <p class="font-display italic text-corail-turquoise-dark/90 mb-3">{tagline}</p>
    <p class="text-sm text-corail-ink/70 mb-4">{description}</p>

    <div class="grid grid-cols-2 gap-3 text-xs text-corail-ink/60 mb-4">
      <div>
        <p class="uppercase tracking-wider text-[10px] text-corail-turquoise-dark mb-1">{t(locale, 'lMeilleurMoment')}</p>
        <p>{bestTime}</p>
      </div>
      <div>
        <p class="uppercase tracking-wider text-[10px] text-corail-turquoise-dark mb-1">{t(locale, 'lServices')}</p>
        <p>{facilities.slice(0,2).join(' · ')}</p>
      </div>
    </div>

    <a href={mapsUrl} target="_blank" rel="noopener" class="btn-secondary w-full justify-center text-sm">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
      {t(locale, 'btnYAller')}
    </a>
  </div>
</article>
