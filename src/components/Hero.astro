---
import Logo from './Logo.astro';
import { t, type Locale } from '../i18n/ui';

interface Props {
  name: string;
  tagline: string;
  welcomeMessage: string;
  coverPhoto: string;
  locale?: Locale;
  villaSlug: string;
}
const { name, tagline, welcomeMessage, coverPhoto, locale = 'fr', villaSlug } = Astro.props;

const urlFR = `/${villaSlug}`;
const urlEN = `/en/${villaSlug}`;
---

<header class="relative h-[90vh] min-h-[500px] w-full overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-corail-turquoise via-corail-turquoise-dark to-corail-ink"></div>
  <img src={coverPhoto} alt={name} class="absolute inset-0 w-full h-full object-cover" loading="eager" onerror="this.remove();" />
  <div class="absolute inset-0 bg-gradient-to-b from-black/10 via-transparent to-black/70"></div>

  <!-- Top bar : logo only, language + nav are in the floating burger menu -->
  <div class="absolute top-0 inset-x-0 p-5 flex items-center justify-start text-white">
    <div class="bg-white/95 backdrop-blur rounded-xl px-3 py-2 shadow-lg">
      <Logo variant="compact" />
    </div>
  </div>

  <!-- Hero text -->
  <div class="absolute bottom-0 inset-x-0 p-6 md:p-10 text-white">
    <p class="text-sm uppercase tracking-[0.3em] opacity-90 mb-3">{t(locale, 'welcomeAbove')}</p>
    <h1 class="text-5xl md:text-7xl font-display leading-[1.05] mb-3">{name}</h1>
    <p class="font-display italic text-lg md:text-xl opacity-95 max-w-md leading-snug">{tagline}</p>
    <p class="mt-4 text-sm md:text-base opacity-85 max-w-md whitespace-pre-line">{welcomeMessage}</p>
  </div>
</header>
