---
interface Props {
  id?: string;
  kicker?: string;
  title: string;
  subtitle?: string;
  background?: 'cream' | 'white';
}
const { id, kicker, title, subtitle, background = 'cream' } = Astro.props;
const bg = background === 'white' ? 'bg-white' : 'bg-corail-cream';
---

<section id={id} class={`${bg} py-12 md:py-20`}>
  <div class="container-wide">
    <header class="mb-8 md:mb-10">
      {kicker && <p class="section-subtitle">{kicker}</p>}
      <h2 class="section-title">{title}</h2>
      {subtitle && <p class="text-corail-ink/70 max-w-2xl">{subtitle}</p>}
    </header>
    <slot />
  </div>
</section>
